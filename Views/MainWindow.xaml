<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CanBusSimulator.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanBusSimulator.Views"
    xmlns:vm="using:CanBusSimulator.ViewModels"
    xmlns:models="using:CanBusSimulator.Models"
    xmlns:sim="using:CanBusSimulator.Simulation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CAN Bus BMS Simulator">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== Custom Title Bar (32 epx = system caption button height) ==================== -->
        <Grid Grid.Row="0"
              x:Name="AppTitleBar"
              Height="32"
              VerticalAlignment="Top"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="CaptionButtonsColumn" Width="138" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"
                        Spacing="8">
                <Image Source="ms-appx:///logo.png"
                       Width="18"
                       Height="18"
                       VerticalAlignment="Center" />
                <TextBlock x:Name="AppTitleText"
                           Text="CAN Bus BMS Simulator"
                           FontSize="12"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock Text="•"
                           Opacity="0.4"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Text="ESP Master → UART (JSON) → BMS Monitor"
                           FontSize="11"
                           Opacity="0.65"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Theme toggle. Sized 46x32 to match Windows 11 caption buttons exactly,
                 with no padding/border so it lines up visually like the Visual Studio
                 installer theme switcher. -->
            <Button Grid.Column="2"
                    x:Name="ThemeToggleButton"
                    Width="46"
                    Height="32"
                    MinWidth="46"
                    MinHeight="32"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Click="OnThemeToggleClick"
                    ToolTipService.ToolTip="Toggle theme (Light / Dark)">
                <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SubtleFillColorSecondary}" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource SubtleFillColorTertiary}" />
                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                </Button.Resources>
                <FontIcon x:Name="ThemeIcon"
                          FontFamily="{StaticResource SymbolThemeFontFamily}"
                          Glyph="&#xE706;"
                          FontSize="12" />
            </Button>
        </Grid>

        <!-- ==================== Main Body ==================== -->
        <!-- ScrollViewer wraps the content so it scrolls when the window is too small,
             while the inner Grid is forced to be at least viewport-height (via
             ContentScroller_SizeChanged in code-behind). That way the * row (Log card)
             still stretches to fill remaining space when content fits — no gap to
             status bar — but content can scroll when the window is small. -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ContentScroller"
                      Padding="14,4,14,0"
                      HorizontalScrollMode="Disabled"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      SizeChanged="ContentScroller_SizeChanged">
        <Grid x:Name="ContentGrid"
              RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" MinHeight="180" />
            </Grid.RowDefinitions>

            <!-- ============= Connection ============= -->
            <Border Grid.Row="0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Serial Port Connection"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="COM port"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <ComboBox x:Name="PortCombo"
                                          ItemsSource="{x:Bind ViewModel.AvailablePorts, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedPort, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch"
                                          DisplayMemberPath="DisplayName" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Spacing="4"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <Button Content="Refresh"
                                        Command="{x:Bind ViewModel.RefreshPortsCommand}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="Baud"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <TextBox Width="92"
                                         Text="{x:Bind ViewModel.BaudRateText, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="4"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <Button Content="{x:Bind ViewModel.ConnectButtonText, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleConnectionCommand}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        MinWidth="98" />
                            </StackPanel>

                            <StackPanel Grid.Column="4"
                                        Spacing="4"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <Button Content="{x:Bind ViewModel.StartButtonText, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.ToggleTransmissionCommand}"
                                        MinWidth="98" />
                            </StackPanel>

                            <StackPanel Grid.Column="5"
                                        Spacing="4"
                                        VerticalAlignment="Bottom"
                                        Margin="6,0,0,0">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <Border Padding="10,4,10,4"
                                        CornerRadius="12"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.ConnectionStatus, Mode=OneWay}"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            <!-- ============= Simulation Parameters ============= -->
            <Border Grid.Row="1"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Simulation Parameters"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <!-- 5 equal columns; each cell is label-above-input -->
                        <Grid ColumnSpacing="12" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                                <ColumnDefinition Width="*" MinWidth="120" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0 -->
                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Mode"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <ToggleSwitch IsOn="{x:Bind ViewModel.AutoMode, Mode=TwoWay}"
                                              OnContent="Auto"
                                              OffContent="Manual"
                                              MinWidth="0" />
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Scenario"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <ComboBox ItemsSource="{x:Bind ViewModel.Scenarios}"
                                          SelectedItem="{x:Bind ViewModel.SelectedScenario, Mode=TwoWay}"
                                          HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 1 -->
                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Pack V"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.PackVoltage, Mode=TwoWay}"
                                           Minimum="60"
                                           Maximum="84"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="0.1"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Current A"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.PackCurrent, Mode=TwoWay}"
                                           Minimum="-150"
                                           Maximum="150"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="0.5"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                                <TextBlock Text="SOC %"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.SocPercent, Mode=TwoWay}"
                                           Minimum="0"
                                           Maximum="100"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="1"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="3" Spacing="4">
                                <TextBlock Text="Cell V"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.CellVoltage, Mode=TwoWay}"
                                           Minimum="3.0"
                                           Maximum="4.2"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="0.001"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Row 2 -->
                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Max temp °C"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.MaxTemp, Mode=TwoWay}"
                                           Minimum="0"
                                           Maximum="80"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="1"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Min temp °C"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.MinTemp, Mode=TwoWay}"
                                           Minimum="0"
                                           Maximum="80"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="1"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2" Spacing="4">
                                <TextBlock Text="Balance mask"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.BalanceMask, Mode=TwoWay}"
                                           Minimum="0"
                                           Maximum="65535"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="1"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            <!-- ============= File replay ============= -->
            <Border Grid.Row="2"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Simulation File Replay"
                                   FontWeight="SemiBold"
                                   FontSize="14" />

                        <Grid ColumnSpacing="10" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="200" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" MinWidth="140" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="File"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <TextBox IsReadOnly="True"
                                         Text="{x:Bind ViewModel.SimulationFilePath, Mode=OneWay}"
                                         HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <Button Content="Browse..."
                                        Click="OnBrowseFileClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Spacing="4"
                                        VerticalAlignment="Bottom"
                                        Margin="6,0,0,0">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <CheckBox Content="Use file data"
                                          IsChecked="{x:Bind ViewModel.UseFileData, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3"
                                        Spacing="4"
                                        VerticalAlignment="Bottom">
                                <TextBlock Text=" "
                                           FontSize="12" />
                                <CheckBox Content="Loop"
                                          IsChecked="{x:Bind ViewModel.LoopFile, Mode=TwoWay}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="Row ms"
                                           FontSize="12"
                                           Opacity="0.7" />
                                <NumberBox Value="{x:Bind ViewModel.FileRowIntervalMs, Mode=TwoWay}"
                                           Minimum="100"
                                           Maximum="60000"
                                           SpinButtonPlacementMode="Compact"
                                           SmallChange="100"
                                           HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.FileInfoText, Mode=OneWay}"
                                   Opacity="0.65"
                                   FontSize="12" />
                    </StackPanel>
                </Border>

            <!-- ============= JSON send interval ============= -->
            <Border Grid.Row="3"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14">
                    <StackPanel Spacing="10">
                        <TextBlock Text="JSON Snapshot Interval (ms)"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                        <TextBlock Text="Periode pengiriman satu baris JSON snapshot ke BMS Monitor."
                                   Opacity="0.65"
                                   FontSize="12" />

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <NumberBox Grid.Column="0"
                                       Value="{x:Bind ViewModel.SendIntervalMs, Mode=TwoWay}"
                                       Minimum="50" Maximum="60000"
                                       SpinButtonPlacementMode="Compact" SmallChange="50"
                                       HorizontalAlignment="Stretch" />
                        </Grid>
                    </StackPanel>
                </Border>

            <!-- ============= Transmission log — fills remaining vertical space ============= -->
            <Border Grid.Row="4"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="14"
                    Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Transmission Log (last 100 frames)"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1"
                                    Content="Clear log"
                                    Margin="0,0,6,0"
                                    Command="{x:Bind ViewModel.ClearLogCommand}" />
                            <Button Grid.Column="2"
                                    Content="Export…"
                                    Margin="0,0,6,0"
                                    Click="OnExportLogClick" />
                            <Button Grid.Column="3"
                                    Content="Reset stats"
                                    Command="{x:Bind ViewModel.ResetStatsCommand}" />
                        </Grid>
                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind ViewModel.StatsText, Mode=OneWay}"
                                   FontSize="12"
                                   Opacity="0.7"
                                   Margin="0,0,0,8" />
                        <ListView Grid.Row="2"
                                  ItemsSource="{x:Bind ViewModel.Log}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  FontFamily="Cascadia Mono, Consolas, monospace"
                                  FontSize="12"
                                  ScrollViewer.HorizontalScrollMode="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="Padding" Value="6,2,6,2" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogEntry">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="320" />
                                            <ColumnDefinition Width="*" MinWidth="240" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{x:Bind Time}" Opacity="0.7" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Decoded}" TextWrapping="NoWrap" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind WireLine}" TextWrapping="NoWrap" Opacity="0.85" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
        </Grid>
        </ScrollViewer>

        <!-- ==================== Status bar (flush with content, no border) ==================== -->
        <Border Grid.Row="2"
                Padding="16,6,16,6"
                BorderThickness="0"
                Background="Transparent">
            <Grid ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{x:Bind ViewModel.RateText, Mode=OneWay}"
                           FontWeight="SemiBold"
                           FontSize="12" />
                <TextBlock Grid.Column="1" Text="|" Opacity="0.4" FontSize="12" />
                <TextBlock Grid.Column="2"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           TextTrimming="CharacterEllipsis"
                           FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
